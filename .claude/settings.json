{
  "respectGitignore": false,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/format.py"
          }
        ]
      }
    ]
  },
  "env": {
    "DOTSETTINGS_FILE": "LayeredCraft.DynamoMapper.sln.DotSettings"
  }
}
